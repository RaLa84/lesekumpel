# Vorlage für n8n-config/.env — die ECHTE Datei .env ist per .gitignore
# ausgeschlossen und wird NIE committet. Kopiere diese Datei nach .env und
# trage die echten Werte ein:  cp n8n-config/.env.example n8n-config/.env
#
# Diese .env.example enthält KEINE Secrets und darf committet werden.

# n8n Cloud REST-API (für die Deploy-/Sync-Scripts)
N8N_API_KEY=dein-n8n-api-key

# Tavily Websuche für Samiras Sachtext-Agent (kostenloser Key: https://tavily.com)
# Wird von einem lokalen Script gelesen, um die n8n-Credential per API anzulegen —
# landet NICHT in der Workflow-JSON / im öffentlichen Repo.
TAVILY_API_KEY=tvly-dein-tavily-key
